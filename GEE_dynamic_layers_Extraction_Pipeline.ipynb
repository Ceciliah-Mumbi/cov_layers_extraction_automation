      "source": [
        "import ee\n",
        "\n",
        "# ── CELL 3: RS_002 & RS_003 — MODIS NDVI & EVI ──────────────────\n",
        "# Exactly matches original 02_MOD13Q1.ipynb pattern\n",
        "print('RS_002/RS_003 — MODIS NDVI & EVI')\n",
        "\n",
        "modis = ee.ImageCollection(\"MODIS/061/MOD13Q1\")\n",
        "\n",
        "# ── Annual composites ────────────────────────────────────────────\n",
        "def annual_modis(band_layer, layer_name):\n",
        "    def _annual(year_date):\n",
        "        start      = ee.Date.fromYMD(year_date, 1, 1)\n",
        "        end        = ee.Date.fromYMD(year_date, 12, 31)\n",
        "        date_range = ee.DateRange(start, end)\n",
        "        name       = start.format('YYYY_MM').cat('_to_').cat(end.format('YYYY_MM'))\n",
        "        return (modis\n",
        "                .filterDate(date_range)\n",
        "                .select(band_layer)\n",
        "                .reduce(reducer=reducer_list)\n",
        "                .multiply(0.0001)\n",
        "                .clip(aoi)\n",
        "                .set({'name': name}))\n",
        "    return year_list.map(_annual)\n",
        "\n",
        "# ── Seasonal composites ──────────────────────────────────────────\n",
        "def seasonal_modis(band_layer):\n",
        "    def _seasonal(year_date, season_start, season_end):\n",
        "        start_year_ee = ee.Number(year_date)\n",
        "        end_year_ee = ee.Number(year_date)\n",
        "\n",
        "        # If the season end month is numerically before the start month,\n",
        "        # it means the season spans across the year boundary, so the end year should be the next year.\n",
        "        end_year_ee = ee.Algorithms.If(\n",
        "            ee.Number(season_end).lt(ee.Number(season_start)),\n",
        "            ee.Number(year_date).add(1),\n",
        "            ee.Number(year_date)\n",
        "        )\n",
        "\n",
        "        start        = ee.Date.fromYMD(start_year_ee, season_start, 1)\n",
        "        # Use advance(1,'month') then subtract 1 day — avoids hardcoded day-30 bug\n",
        "        end          = ee.Date.fromYMD(end_year_ee, season_end, 1).advance(1, 'month').advance(-1, 'day')\n",
        "        date_range   = ee.DateRange(start, end)\n",
        "        season_label = ee.Algorithms.If(\n",
        "            ee.Number(season_start).eq(dry_start), 'dry', 'wet')\n",
        "        return (modis\n",
        "                .filterDate(date_range)\n",
        "                .select(band_layer)\n",
        "                .reduce(reducer=reducer_list)\n",
        "                .multiply(0.0001)\n",
        "                .clip(aoi)\n",
        "                .set({'season': season_label, 'year': year_date}))\n",
        "\n",
        "    def _dry(year):  return _seasonal(year, dry_start,  dry_end)\n",
        "    def _wet(year):  return _seasonal(year, rain_start, rain_end)\n",
        "\n",
        "    return year_list.map(_dry), year_list.map(_wet)\n",
        "\n",
        "# ── Export helper (same signature as original) ───────────────────\n",
        "def export_modis_tasks(img_list, layer_name, band_layer, season_type='annual'):\n",
        "    n = ee.List.length(img_list).getInfo()\n",
        "    for i in range(n):\n",
        "        output_img  = ee.Image(img_list.get(i)).select(band_select)\n",
        "        if season_type == 'annual':\n",
        "            output_name = f\"{layer_name}_{aoi_name}_{img_col_reducer}_{ee.String(output_img.get('name')).getInfo()}\"\n",
        "        else:\n",
        "            year_val    = ee.Number(output_img.get('year')).getInfo()\n",
        "            season_val  = ee.String(output_img.get('season')).getInfo()\n",
        "            output_name = f\"{layer_name}_{aoi_name}_{img_col_reducer}_{year_val}_{season_val}\"\n",
        "\n",
        "        task = ee.batch.Export.image.toDrive(\n",
        "            image          = output_img,\n",
        "            region         = aoi.geometry(),\n",
        "            description    = \"EXPORT IMAGE TO DRIVE\",\n",
        "            folder         = DRIVE_FOLDER,\n",
        "            fileNamePrefix = output_name,\n",
        "            scale          = 250,\n",
        "            maxPixels      = 10e12,\n",
        "            crs            = \"EPSG:4326\"\n",
        "        )\n",
        "        task.start()\n",
        "        print(f'  STARTED: {output_name}')\n",
        "\n",
        "# ── Run for NDVI (RS_002) ────────────────────────────────────────\n",
        "print('\\n  → NDVI annual')\n",
        "ndvi_annual           = annual_modis('NDVI', 'RS_002')\n",
        "export_modis_tasks(ndvi_annual, 'RS_002', 'NDVI', 'annual')\n",
        "\n",
        "ndvi_dry, ndvi_wet    = seasonal_modis('NDVI')\n",
        "print('  → NDVI dry')\n",
        "export_modis_tasks(ndvi_dry, 'RS_002', 'NDVI', 'seasonal')\n",
        "print('  → NDVI wet')\n",
        "export_modis_tasks(ndvi_wet, 'RS_002', 'NDVI', 'seasonal')\n",
        "\n",
        "# ── Run for EVI (RS_003) ─────────────────────────────────────────\n",
        "print('\\n  → EVI annual')\n",
        "evi_annual            = annual_modis('EVI', 'RS_003')\n",
        "export_modis_tasks(evi_annual, 'RS_003', 'EVI', 'annual')\n",
        "\n",
        "evi_dry, evi_wet      = seasonal_modis('EVI')\n",
        "print('  → EVI dry')\n",
        "export_modis_tasks(evi_dry, 'RS_003', 'EVI', 'seasonal')\n",
        "print('  → EVI wet')\n",
        "export_modis_tasks(evi_wet, 'RS_003', 'EVI', 'seasonal')"
      ]
    },
