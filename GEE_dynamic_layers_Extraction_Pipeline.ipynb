        "# ── CELL 2: Shared configuration ────────────────────────────────\n",
        "# Area of interest — matches your asset visible in GEE Assets panel\n",
        "aoi      = ee.FeatureCollection(\"projects/cmumbi/assets/ORKA_Long_Term_Buffered\")\n",
        "aoi_name = \"ORKCA\"\n",
        "\n",
        "# Export folder in Google Drive\n",
        "DRIVE_FOLDER = \"GEE_exports\"\n",
        "\n",
        "# Image reducer — controls which statistical band gets exported\n",
        "# Options: mean | median | min | max | stdDev | sum | product\n",
        "img_col_reducer = \"mean\"\n",
        "\n",
        "# Year range\n",
        "start_year = 2025\n",
        "end_year   = 2025\n",
        "year_list  = ee.List(list(range(start_year, end_year + 1)))\n",
        "\n",
        "# Season parameters (month numbers) — using ee.Date avoids hardcoded day-30 errors\n",
        "# Wet/rain season\n",
        "rain_start = 4   # Nov\n",
        "rain_end   = 11  # April\n",
        "# Dry season\n",
        "dry_start  = 5   # May\n",
        "dry_end    = 10  # October\n",
        "\n",
        "# Shared reducer — same as original script\n",
        "reducer_list = (ee.Reducer.mean()\n",
        "    .combine(reducer2=ee.Reducer.median(),  sharedInputs=True)\n",
        "    .combine(reducer2=ee.Reducer.min(),     sharedInputs=True)\n",
        "    .combine(reducer2=ee.Reducer.max(),     sharedInputs=True)\n",
        "    .combine(reducer2=ee.Reducer.stdDev(),  sharedInputs=True)\n",
        "    .combine(reducer2=ee.Reducer.sum(),     sharedInputs=True)\n",
        "    .combine(reducer2=ee.Reducer.product(), sharedInputs=True))\n",
        "\n",
        "# Band selector — picks e.g. 'NDVI_mean' or 'EVI_mean'\n",
        "band_select = \".*\" + img_col_reducer\n",
        "\n",
        "print('✓ Config ready')\n",
        "print(f'  AOI       : {aoi_name}')\n",
        "print(f'  Years     : {start_year}–{end_year}')\n",
        "print(f'  Reducer   : {img_col_reducer}')\n",
        "print(f'  Dry season: months {dry_start}–{dry_end}')\n",
        "print(f'  Wet season: months {rain_start}–{rain_end}')"
      ]
