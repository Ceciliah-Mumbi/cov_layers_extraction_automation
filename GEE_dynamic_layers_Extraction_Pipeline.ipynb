      "source": [
        "import ee\n",
        "\n",
        "# ── CELL 4: RS_001 — Sentinel-2 NDVI ────────────────────────────\n",
        "print('RS_001 — Sentinel-2 NDVI')\n",
        "\n",
        "def mask_s2_clouds(image):\n",
        "    scl  = image.select('SCL')\n",
        "    mask = scl.neq(3).And(scl.neq(8)).And(scl.neq(9)).And(scl.neq(10)).And(scl.neq(11))\n",
        "    return image.updateMask(mask).divide(10000)\n",
        "\n",
        "s2 = (ee.ImageCollection('COPERNICUS/S2_SR_HARMONIZED')\n",
        "      .filterBounds(aoi)\n",
        "      .filter(ee.Filter.lt('CLOUDY_PIXEL_PERCENTAGE', 20))\n",
        "      .map(mask_s2_clouds))\n",
        "\n",
        "def s2_seasonal(year_date, season_start, season_end, season_label):\n",
        "    start_year_ee = ee.Number(year_date)\n",
        "    end_year_ee = ee.Number(year_date)\n",
        "\n",
        "    # If the season end month is numerically before the start month,\n",
        "    # it means the season spans across the year boundary, so the end year should be the next year.\n",
        "    end_year_ee = ee.Algorithms.If(\n",
        "        ee.Number(season_end).lt(ee.Number(season_start)),\n",
        "        ee.Number(year_date).add(1),\n",
        "        ee.Number(year_date)\n",
        "    )\n",
        "\n",
        "    start      = ee.Date.fromYMD(start_year_ee, season_start, 1)\n",
        "    end        = ee.Date.fromYMD(end_year_ee, season_end, 1).advance(1,'month').advance(-1,'day')\n",
        "    date_range = ee.DateRange(start, end)\n",
        "\n",
        "    # Filter the collection\n",
        "    filtered_collection = s2.filterDate(date_range)\n",
        "\n",
        "    # Use ee.Algorithms.If to handle empty collections gracefully\n",
        "    # If the collection is empty, return a dummy image marked for skipping export.\n",
        "    result_image = ee.Algorithms.If(\n",
        "        filtered_collection.size().eq(0),\n",
        "        ee.Image(0).set({'season': season_label, 'year': year_date, 'skip_export': True}), # Mark for skipping\n",
        "        filtered_collection\n",
        "            .map(lambda img: img.normalizedDifference(['B8','B4']).rename('NDVI'))\n",
        "            .reduce(reducer=reducer_list)\n",
        "            .clip(aoi)\n",
        "            .set({'season': season_label, 'year': year_date})\n",
        "    )\n",
        "\n",
        "    return ee.Image(result_image)\n",
        "\n",
        "def _s2_dry(year):  return s2_seasonal(year, dry_start,  dry_end,  'dry')\n",
        "def _s2_wet(year):  return s2_seasonal(year, rain_start, rain_end, 'wet')\n",
        "\n",
        "s2_dry = year_list.map(_s2_dry)\n",
        "s2_wet = year_list.map(_s2_wet)\n",
        "\n",
        "for label, img_list in [('dry', s2_dry), ('wet', s2_wet)]:\n",
        "    n = ee.List.length(img_list).getInfo()\n",
        "    for i in range(n):\n",
        "        output_img  = ee.Image(img_list.get(i))\n",
        "        # Check if the image is marked for skipping using Python logic\n",
        "        if output_img.propertyNames().contains('skip_export').getInfo() and output_img.get('skip_export').getInfo():\n",
        "            year_val = ee.Number(output_img.get('year')).getInfo()\n",
        "            print(f'  SKIPPING: RS_001_{aoi_name}_{img_col_reducer}_{year_val}_{label} (empty collection)')\n",
        "            continue # Skip to the next iteration\n",
        "\n",
        "        output_img  = output_img.select(band_select)\n",
        "        year_val    = ee.Number(output_img.get('year')).getInfo()\n",
        "        output_name = f\"RS_001_{aoi_name}_{img_col_reducer}_{year_val}_{label}\"\n",
        "        task = ee.batch.Export.image.toDrive(\n",
        "            image=output_img, region=aoi.geometry(),\n",
        "            description=\"EXPORT IMAGE TO DRIVE\", folder=DRIVE_FOLDER,\n",
        "            fileNamePrefix=output_name, scale=10,\n",
        "            maxPixels=10e12, crs=\"EPSG:4326\")\n",
        "        task.start()\n",
        "        print(f'  STARTED: {output_name}')"
      ]
