      "source": [
        "# ── CELL 10: RS_049-052 — SMAP Soil Moisture ─────────────────────\n",
        "print('RS_049–052 — SMAP Soil Moisture & Wetness')\n",
        "\n",
        "smap_bands = [\n",
        "    ('sm_surface',          'TSM', 'RS_049'),\n",
        "    ('sm_rootzone',         'RSM', 'RS_050'),\n",
        "    ('sm_surface_wetness',  'TSW', 'RS_051'),\n",
        "    ('sm_rootzone_wetness', 'RSW', 'RS_052'),\n",
        "]\n",
        "\n",
        "smap = ee.ImageCollection('NASA/SMAP/SPL4SMGP/008').filterBounds(aoi)\n",
        "\n",
        "for season_label, s_start, s_end in [('dry', dry_start, dry_end), ('wet', rain_start, rain_end)]:\n",
        "    def _smap_season(year_date):\n",
        "        start = ee.Date.fromYMD(year_date, s_start, 1)\n",
        "        end   = ee.Date.fromYMD(year_date, s_end, 1).advance(1,'month').advance(-1,'day')\n",
        "        date_range = ee.DateRange(start, end)\n",
        "\n",
        "        filtered_collection = smap.filterDate(date_range)\n",
        "\n",
        "        # Use ee.Algorithms.If to handle empty collections gracefully\n",
        "        result_image = ee.Algorithms.If(\n",
        "            filtered_collection.size().eq(0),\n",
        "            ee.Image(0).set({'season': season_label, 'year': year_date, 'skip_export': True}), # Mark for skipping\n",
        "            filtered_collection\n",
        "                .mean()\n",
        "                .clip(aoi)\n",
        "                .set({'season': season_label, 'year': year_date})\n",
        "        )\n",
        "        return ee.Image(result_image)\n",
        "\n",
        "    smap_list = year_list.map(_smap_season)\n",
        "    n         = ee.List.length(smap_list).getInfo()\n",
        "    for i in range(n):\n",
        "        composite = ee.Image(smap_list.get(i))\n",
        "\n",
        "        # Check if the image is marked for skipping using Python logic\n",
        "        if composite.propertyNames().contains('skip_export').getInfo() and composite.get('skip_export').getInfo():\n",
        "            year_val = ee.Number(composite.get('year')).getInfo()\n",
        "            print(f'  SKIPPING: SMAP_{aoi_name}_{year_val}_{season_label} (empty collection)') # Simplified output name for skipping\n",
        "            continue # Skip to the next iteration\n",
        "\n",
        "        year_val  = ee.Number(composite.get('year')).getInfo()\n",
        "        for band_name, short_name, layer_id in smap_bands:\n",
        "            output_img  = composite.select(band_name).rename(short_name)\n",
        "            output_name = f\"{layer_id}_{aoi_name}_{short_name}_{year_val}_{season_label}\"\n",
        "            task = ee.batch.Export.image.toDrive(\n",
