        "# ── CELL 6: RS_004 — Burned Area ────────────────────────────────\n",
        "print('RS_004 — Burned Area (MCD64A1) annual')\n",
        "\n",
        "def annual_burn(year_date):\n",
        "    start = ee.Date.fromYMD(year_date, 1, 1)\n",
        "    end   = ee.Date.fromYMD(year_date, 12, 31)\n",
        "    name  = start.format('YYYY')\n",
        "    return (ee.ImageCollection('MODIS/061/MCD64A1')\n",
        "              .filterDate(ee.DateRange(start, end))\n",
        "              .select('BurnDate')\n",
        "              .max()\n",
        "              .rename('BurnDate')\n",
        "              .clip(aoi)\n",
        "              .set({'name': name}))\n",
        "\n",
        "burn_list = year_list.map(annual_burn)\n",
        "n = ee.List.length(burn_list).getInfo()\n",
        "for i in range(n):\n",
        "    output_img  = ee.Image(burn_list.get(i))\n",
        "    year_val    = ee.String(output_img.get('name')).getInfo()\n",
        "    output_name = f\"RS_004_{aoi_name}_BurnDate_{year_val}\"\n",
        "    task = ee.batch.Export.image.toDrive(\n",
        "        image=output_img, region=aoi.geometry(),\n",
        "        description=\"EXPORT IMAGE TO DRIVE\", folder=DRIVE_FOLDER,\n",
        "        fileNamePrefix=output_name, scale=500,\n",
        "        maxPixels=10e12, crs=\"EPSG:4326\")\n",
        "    task.start()\n",
        "    print(f'  STARTED: {output_name}')"
      ]
