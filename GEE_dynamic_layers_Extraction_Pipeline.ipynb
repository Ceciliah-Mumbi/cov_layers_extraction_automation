      "source": [
        "# ── CELL 8: RS_013 — MODIS NPP ───────────────────────────────────\n",
        "# MOD17A3HGF is annual — latest available as of 2025 is 2024\n",
        "print('RS_013 — MODIS NPP (annual; using 2024 as latest available)')\n",
        "\n",
        "npp_year = min(start_year, 2024)\n",
        "\n",
        "def annual_npp(year_date):\n",
        "    start = ee.Date.fromYMD(year_date, 1, 1)\n",
        "    end   = ee.Date.fromYMD(year_date, 12, 31)\n",
        "    name  = start.format('YYYY')\n",
        "    return (ee.ImageCollection('MODIS/061/MOD17A3HGF')\n",
        "              .filterDate(ee.DateRange(start, end))\n",
        "              .select('Npp')\n",
        "              .map(lambda img: img.multiply(0.0001).copyProperties(img, img.propertyNames()))\n",
        "              .first()\n",
        "              .rename('NPP')\n",
        "              .clip(aoi)\n",
        "              .set({'name': name}))\n",
        "\n",
        "npp_year_list = ee.List([npp_year])\n",
        "npp_list      = npp_year_list.map(annual_npp)\n",
        "n = ee.List.length(npp_list).getInfo()\n",
        "for i in range(n):\n",
        "    output_img  = ee.Image(npp_list.get(i))\n",
        "    year_val    = ee.String(output_img.get('name')).getInfo()\n",
        "    output_name = f\"RS_013_{aoi_name}_NPP_{year_val}\"\n",
        "    task = ee.batch.Export.image.toDrive(\n",
        "        image=output_img, region=aoi.geometry(),\n",
        "        description=\"EXPORT IMAGE TO DRIVE\", folder=DRIVE_FOLDER,\n",
        "        fileNamePrefix=output_name, scale=500,\n",
        "        maxPixels=10e12, crs=\"EPSG:4326\")\n",
        "    task.start()\n",
        "    print(f'  STARTED: {output_name}')"
      ]
