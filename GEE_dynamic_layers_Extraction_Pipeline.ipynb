        "# ── CELL 7: RS_012 — CHIRPS Annual Precipitation ─────────────────\n",
        "print('RS_012 — CHIRPS Annual Precipitation')\n",
        "\n",
        "def annual_chirps(year_date):\n",
        "    start = ee.Date.fromYMD(year_date, 1, 1)\n",
        "    end   = ee.Date.fromYMD(year_date, 12, 31)\n",
        "    name  = start.format('YYYY')\n",
        "    return (ee.ImageCollection('UCSB-CHG/CHIRPS/DAILY')\n",
        "              .filterDate(ee.DateRange(start, end))\n",
        "              .select('precipitation')\n",
        "              .sum()\n",
        "              .rename('PrecipY')\n",
        "              .clip(aoi)\n",
        "              .set({'name': name}))\n",
        "\n",
        "chirps_list = year_list.map(annual_chirps)\n",
        "n = ee.List.length(chirps_list).getInfo()\n",
        "for i in range(n):\n",
        "    output_img  = ee.Image(chirps_list.get(i))\n",
        "    year_val    = ee.String(output_img.get('name')).getInfo()\n",
        "    output_name = f\"RS_012_{aoi_name}_PrecipY_{year_val}\"\n",
        "    task = ee.batch.Export.image.toDrive(\n",
        "        image=output_img, region=aoi.geometry(),\n",
        "        description=\"EXPORT IMAGE TO DRIVE\", folder=DRIVE_FOLDER,\n",
        "        fileNamePrefix=output_name, scale=5566,\n",
        "        maxPixels=10e12, crs=\"EPSG:4326\")\n",
        "    task.start()\n",
        "    print(f'  STARTED: {output_name}')"
      ]
