      "source": [
        "# ── CELL 5: RS_017/018/019 — Landsat-8 NDVI, EVI, MSAVI ─────────\n",
        "print('RS_017/018/019 — Landsat-8 vegetation indices')\n",
        "\n",
        "def mask_l8_clouds(image):\n",
        "    qa   = image.select('QA_PIXEL')\n",
        "    mask = qa.bitwiseAnd(1 << 3).eq(0).And(qa.bitwiseAnd(1 << 5).eq(0))\n",
        "    return image.updateMask(mask).multiply(0.0000275).add(-0.2)\n",
        "\n",
        "def add_l8_indices(image):\n",
        "    ndvi  = image.normalizedDifference(['SR_B5','SR_B4']).rename('NDVI')\n",
        "    evi   = image.expression(\n",
        "        '2.5*((NIR-RED)/(NIR+6*RED-7.5*BLUE+1))',\n",
        "        {'NIR':image.select('SR_B5'),'RED':image.select('SR_B4'),'BLUE':image.select('SR_B2')}\n",
        "    ).rename('EVI')\n",
        "    msavi = image.expression(\n",
        "        '(2*NIR+1-sqrt(pow((2*NIR+1),2)-8*(NIR-RED)))/2',\n",
        "        {'NIR':image.select('SR_B5'),'RED':image.select('SR_B4')}\n",
        "    ).rename('MSAVI')\n",
        "    return image.addBands([ndvi, evi, msavi])\n",
        "\n",
        "l8 = (ee.ImageCollection('LANDSAT/LC08/C02/T1_L2')\n",
        "      .filterBounds(aoi)\n",
        "      .filter(ee.Filter.lt('CLOUD_COVER', 20))\n",
        "      .map(mask_l8_clouds)\n",
        "      .map(add_l8_indices))\n",
        "\n",
        "l8_layers = [\n",
        "    ('NDVI',  'RS_017'),\n",
        "    ('EVI',   'RS_018'),\n",
        "    ('MSAVI', 'RS_019'),\n",
        "]\n",
        "\n",
        "for band_name, layer_id in l8_layers:\n",
        "    for season_label, s_start, s_end in [('dry', dry_start, dry_end), ('wet', rain_start, rain_end)]:\n",
        "        def _l8_season(year_date):\n",
        "            start_year_ee = ee.Number(year_date)\n",
        "            end_year_ee = ee.Number(year_date)\n",
        "\n",
        "            # If the season end month is numerically before the start month,\n",
        "            # it means the season spans across the year boundary, so the end year should be the next year.\n",
        "            end_year_ee = ee.Algorithms.If(\n",
        "                ee.Number(s_end).lt(ee.Number(s_start)),\n",
        "                ee.Number(year_date).add(1),\n",
        "                ee.Number(year_date)\n",
        "            )\n",
        "\n",
        "            start = ee.Date.fromYMD(start_year_ee, s_start, 1)\n",
        "            end   = ee.Date.fromYMD(end_year_ee, s_end, 1).advance(1,'month').advance(-1,'day')\n",
        "            date_range = ee.DateRange(start, end)\n",
        "\n",
        "            # Filter the collection and select the specific band\n",
        "            filtered_collection = l8.filterDate(date_range).select(band_name)\n",
        "\n",
        "            # Define expected bands after reduction\n",
        "            reducer_suffixes = ['mean', 'median', 'min', 'max', 'stdDev', 'sum', 'product']\n",
        "            expected_bands = [f'{band_name}_{suffix}' for suffix in reducer_suffixes]\n",
        "\n",
        "            # Use ee.Algorithms.If to handle empty collections gracefully\n",
        "            result_image = ee.Algorithms.If(\n",
        "                filtered_collection.size().eq(0),\n",
        "                ee.Image(0).set({'season': season_label, 'year': year_date, 'skip_export': True}), # Mark for skipping\n",
        "                filtered_collection\n",
        "                    .reduce(reducer=reducer_list)\n",
        "                    .clip(aoi)\n",
        "                    .set({'season': season_label, 'year': year_date})\n",
        "            )\n",
        "            return ee.Image(result_image)\n",
        "\n",
        "        img_list = year_list.map(_l8_season)\n",
        "        n        = ee.List.length(img_list).getInfo()\n",
        "        for i in range(n):\n",
        "            output_img  = ee.Image(img_list.get(i))\n",
        "            # Check if the image is marked for skipping using Python logic\n",
        "            if output_img.propertyNames().contains('skip_export').getInfo() and output_img.get('skip_export').getInfo():\n",
        "                year_val = ee.Number(output_img.get('year')).getInfo()\n",
        "                print(f'  SKIPPING: {layer_id}_{aoi_name}_{img_col_reducer}_{year_val}_{season_label} (empty collection)')\n",
        "                continue # Skip to the next iteration\n",
        "\n",
        "            output_img  = output_img.select(band_select)\n",
        "            year_val    = ee.Number(output_img.get('year')).getInfo()\n",
        "            output_name = f\"{layer_id}_{aoi_name}_{img_col_reducer}_{year_val}_{season_label}\"\n",
        "            task = ee.batch.Export.image.toDrive(\n",
        "                image=output_img, region=aoi.geometry(),\n",
