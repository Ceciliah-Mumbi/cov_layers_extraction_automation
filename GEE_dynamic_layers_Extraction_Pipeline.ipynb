        "# ── CELL 9: RS_014/015/016 — MOD44B Vegetation Cover ─────────────\n",
        "print('RS_014/015/016 — Vegetation Cover (MOD44B)')\n",
        "\n",
        "vcf_year      = min(start_year, 2024)\n",
        "vcf_year_list = ee.List([vcf_year])\n",
        "\n",
        "vcf_bands = [\n",
        "    ('Percent_Tree_Cover',        'Tree',  'RS_014'),\n",
        "    ('Percent_NonTree_Vegetation','Bush',  'RS_015'),\n",
        "    ('Percent_NonVegetated',      'Bare',  'RS_016'),\n",
        "]\n",
        "\n",
        "def annual_vcf(year_date):\n",
        "    start = ee.Date.fromYMD(year_date, 1, 1)\n",
        "    end   = ee.Date.fromYMD(year_date, 12, 31)\n",
        "    name  = start.format('YYYY')\n",
        "    return (ee.ImageCollection('MODIS/061/MOD44B')\n",
        "              .filterDate(ee.DateRange(start, end))\n",
        "              .first()\n",
        "              .clip(aoi)\n",
        "              .set({'name': name}))\n",
        "\n",
        "vcf_list = vcf_year_list.map(annual_vcf)\n",
        "vcf_img  = ee.Image(vcf_list.get(0))\n",
        "year_val = ee.String(vcf_img.get('name')).getInfo()\n",
        "\n",
        "for band_name, out_name, layer_id in vcf_bands:\n",
        "    # Mask water pixels (value == 200)\n",
        "    band        = vcf_img.select(band_name)\n",
        "    output_img  = band.updateMask(band.neq(200)).rename(out_name)\n",
        "    output_name = f\"{layer_id}_{aoi_name}_{out_name}_{year_val}\"\n",
        "    task = ee.batch.Export.image.toDrive(\n",
        "        image=output_img, region=aoi.geometry(),\n",
        "        description=\"EXPORT IMAGE TO DRIVE\", folder=DRIVE_FOLDER,\n",
        "        fileNamePrefix=output_name, scale=250,\n",
        "        maxPixels=10e12, crs=\"EPSG:4326\")\n",
        "    task.start()\n",
        "    print(f'  STARTED: {output_name}')"
      ]
